<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER_LEFT" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="400.0" spacing="10.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.ttkelaw.todo.controller.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <TableView fx:id="tehtavaTaulu" VBox.vgrow="ALWAYS" />
   <HBox spacing="10.0" VBox.vgrow="NEVER">
      <children>
         <TextField fx:id="uusiTehtavaNimi" HBox.hgrow="ALWAYS" />
          <Button fx:id="lisaaUusiTehtavaPainike" text="Lisää tehtävä" />
      </children>
   </HBox>
   <Button fx:id="poistaValittuPainike" mnemonicParsing="false" text="Poista tehtävä" />
</VBox>
